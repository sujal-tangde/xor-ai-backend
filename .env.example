# Redis (stores the last MAX_CHAT_MESSAGES per conversation)
REDIS_URL=redis://default:YOUR_REDIS_PASSWORD@your-redis-host.db.redis.io:16840
MAX_CHAT_MESSAGES=20

# Background processing: number of parallel worker processes (worker.py).
# Each consumes the same queue, so N workers analyze N files concurrently.
WORKER_COUNT=2

# Bedrock (uncomment to use cloud instead of Ollama)
LLM_MODEL=bedrock/qwen.qwen3-vl-235b-a22b
LLM_API_BASE=""
LLM_API_KEY="your-bedrock-api-key"
LLM_TOOLS_ENABLED=true
AWS_REGION=us-east-1

EMBEDDING_MODEL = bedrock/amazon.titan-embed-text-v2:0
EMBEDDING_API_BASE = ""
EMBEDDING_API_KEY = "your-bedrock-api-key"
EMBEDDING_SEND_DIMENSIONS = true

EMBEDDING_DIM = 1024


# Tavily web search
TAVILY_API_KEY=your-tavily-api-key


# postgre sql database
DIRECT_URL="postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:5432/postgres"
SUPABASE_URL="https://your-project-ref.supabase.co"
STORAGE_BUCKET_1 = "compressed_uploads"
STORAGE_BUCKET_2 = "original_uploads"

SUPABASE_SERVICE_KEY = "your-supabase-service-role-key"
SUPABASE_ANON_KEY="your-supabase-anon-key"
AUTH_REDIRECT_URL="http://localhost:5173/auth/callback"
# AUTH_REDIRECT_URL="https://should-cost-frontend.vercel.app/auth/callback"



DIGIKEY_CLIENT_ID = "your-digikey-client-id"
DIGIKEY_CLIENT_SECRET = "your-digikey-client-secret"


# --- Should-cost report generation ---

# Mouser Search API (component BOM pricing — prices are already INR for an INR account)
MOUSER_API_KEY="your-mouser-api-key"
# MOUSER_API_BASE="https://api.mouser.com/api/v2"

# PCBWay partner API (PCB fabrication quote — prices are USD, converted to INR)
PCBWAY_API_KEY="your-pcbway-api-key"
# PCBWAY_API_BASE="https://api-partner.pcbway.com"

# Frankfurter FX (no key needed; only the PCBWay USD quote is converted to INR)
# FRANKFURTER_API_BASE="https://api.frankfurter.dev/v1"

# Supabase storage bucket the rendered report PDFs are uploaded to
REPORTS_BUCKET="reports"

# Per-failure debug logging: when true, one timestamped JSON file is written per
# failed stage (Mouser/PCBWay/FX/etc.) for debugging; set false to disable entirely.
REPORT_FAILURE_LOG_ENABLED="true"
# Folder for per-failure debug JSON files (one timestamped file per failed stage)
# REPORT_FAILURE_LOG_DIR="logs/report_failures"

# Order quantities the whole cost model is run at (the volume curve)
# REPORT_VOLUME_CURVE="1,100,1000,10000"
# REPORT_DEFAULT_VOLUME=1000
# REPORT_USD_INR_FALLBACK=85.0

# Indian EMS assembly rate card (INR): one-time setup + stencil NRE, per-joint rate
# ASSEMBLY_SETUP_FEE_INR=1000.0
# ASSEMBLY_STENCIL_FEE_INR=500.0
# ASSEMBLY_RATE_PER_JOINT_INR=0.15

# PostgreSQL database connection settings, read only
PG_HOST=
PG_PORT=
PG_USER=
PG_PASSWORD=
PG_DATABASE=
PG_SCHEMA=
PG_TABLE=
PG_ENABLED=
